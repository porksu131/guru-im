# 服务器配置
MEDIA_PORT=3000
MEDIA_HOST=0.0.0.0

# 网络配置 - 必须修改为你的服务器公网IP！如果是本地启动改为本机地址即可
ANNOUNCED_IP=192.168.2.130

# Node.js 环境
NODE_ENV=production

# mediasoup 配置
MEDIASOUP_NUM_WORKERS=1
MEDIASOUP_LOG_LEVEL=warn
MEDIASOUP_MIN_PORT=40000
MEDIASOUP_MAX_PORT=40100

# TURN 服务器配置
TURN_SERVER=coturn
TURN_PORT=3478
TURN_USERNAME=coturn
TURN_PASSWORD=coturn