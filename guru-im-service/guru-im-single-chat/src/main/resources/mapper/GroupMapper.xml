<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.guru.im.single.mapper.GroupMapper">

    <select id="selectGroupMembers" parameterType="long"  resultType="java.lang.Long">
        SELECT user_id FROM im_group_member
        WHERE group_id = #{groupId} AND member_status = 1
        ORDER BY member_role DESC, join_time ASC
    </select>

</mapper>