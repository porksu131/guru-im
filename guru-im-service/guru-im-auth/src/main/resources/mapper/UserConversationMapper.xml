<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.guru.im.auth.mapper.UserConversationMapper">

    <resultMap id="BaseResultMap" type="com.guru.im.auth.model.pojo.UserConversation">
        <id column="id" property="id" />
        <result column="user_id" property="userId" />
        <result column="conversation_id" property="conversationId" />
        <result column="conversation_type" property="conversationType" />
        <result column="unread_count" property="unreadCount" />
        <result column="last_read_seq" property="lastReadSeq" />
        <result column="is_top" property="isTop" />
        <result column="is_mute" property="isMute" />
        <result column="show_nickname" property="showNickname" />
        <result column="status" property="status" />
        <result column="create_time" property="createTime" />
        <result column="update_time" property="updateTime" />
    </resultMap>

    <resultMap id="UserConversationWithBaseInfoMap" type="com.guru.im.auth.model.pojo.UserConversation" extends="BaseResultMap">
        <result column="conv_key" property="conversationKey" />
        <result column="conv_type" property="conversationType" />
        <result column="conv_name" property="conversationName" />
        <result column="conv_avatar" property="conversationAvatar" />
        <result column="last_message_id" property="lastMessageId" />
        <result column="last_message_time" property="lastMessageTime" />
        <result column="last_message_content" property="lastMessageContent" />
        <result column="last_message_sender" property="lastMessageSender" />
    </resultMap>

    <sql id="Base_Column_List">
        id, user_id, conversation_id, conversation_type, unread_count,
        last_read_seq, is_top, is_mute, show_nickname, status,
        create_time, update_time
    </sql>

    <insert id="insert" parameterType="com.guru.im.auth.model.pojo.UserConversation">
        INSERT INTO im_user_conversation (
        <include refid="Base_Column_List" />
        ) VALUES (
        #{id}, #{userId}, #{conversationId}, #{conversationType}, #{unreadCount},
        #{lastReadSeq}, #{isTop}, #{isMute}, #{showNickname}, #{status},
        #{createTime}, #{updateTime}
        )
    </insert>
</mapper>